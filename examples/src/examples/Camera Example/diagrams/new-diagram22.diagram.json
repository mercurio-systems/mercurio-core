{
  "schema": "mercurio.diagram.v1",
  "version": 1,
  "kind": "structure",
  "title": "New Diagram22",
  "root": "Camera",
  "query": {
    "relations": [
      "features",
      "specializes",
      "metatype",
      "imports",
      "subsetted_features",
      "redefined_features",
      "specialized_features"
    ],
    "direction": "parents",
    "depth": 4,
    "include_libraries": true,
    "include_user_model": true,
    "max_nodes": 350,
    "max_edges": 900
  },
  "layout": {
    "engine": "dagre",
    "direction": "LR"
  },
  "style": {
    "show_attributes": true,
    "show_edge_labels": true,
    "group_by_layer": true
  },
  "mode": "artifact"
}
