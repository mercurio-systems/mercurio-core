{
  "elements": [
    {
      "id": "type.Engine",
      "kind": "SysML::Systems::PartDefinition",
      "layer": 2,
      "properties": {
        "specializes": ["SysML::Systems::PartDefinition"]
      }
    },
    {
      "id": "feature.engine",
      "kind": "KerML::Core::Feature",
      "layer": 2,
      "properties": {
        "owner": "type.Vehicle",
        "type": "type.Engine"
      }
    },
    {
      "id": "feature.parts",
      "kind": "KerML::Core::Feature",
      "layer": 2,
      "properties": {
        "owner": "assembly.VehicleInstance",
        "items": ["part.engine_left", "part.engine_right"]
      }
    },
    {
      "id": "df.partCount",
      "kind": "KerML::Core::Feature",
      "layer": 2,
      "properties": {
        "owner": "type.Vehicle",
        "expression": "count(self.features)"
      }
    },
    {
      "id": "df.totalMass",
      "kind": "KerML::Core::Feature",
      "layer": 2,
      "properties": {
        "owner": "assembly.VehicleInstance",
        "expression": "sum(self.parts.mass)"
      }
    },
    {
      "id": "type.Vehicle",
      "kind": "SysML::Systems::PartDefinition",
      "layer": 2,
      "properties": {
        "specializes": ["SysML::Systems::PartDefinition"],
        "features": ["feature.engine", "df.partCount"]
      }
    },
    {
      "id": "type.Car",
      "kind": "SysML::Systems::PartDefinition",
      "layer": 2,
      "properties": {
        "specializes": ["type.Vehicle"]
      }
    },
    {
      "id": "part.engine_left",
      "kind": "type.Engine",
      "layer": 2,
      "properties": {}
    },
    {
      "id": "part.engine_right",
      "kind": "type.Engine",
      "layer": 2,
      "properties": {}
    },
    {
      "id": "assembly.VehicleInstance",
      "kind": "type.Vehicle",
      "layer": 2,
      "properties": {
        "parts": ["part.engine_left", "part.engine_right"]
      }
    }
  ]
}
